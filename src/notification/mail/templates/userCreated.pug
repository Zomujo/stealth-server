extends baseEmail

block content
  p Dear #{fullName},
  p You have been added as a User to Stealth IMS. We're excited to have you on board!
  hr
  p Account Details:
  ul
    li Full Name: #{fullName}
    li Email: #{email}
    li Role: #{role}
    li Password: #{password}
    li Created At: #{updatedAt}
  hr
  p
    | You can now log in to your account:
  p
    a(
      href=clientUrl + "/auth/login", 
      style="display:inline-block;padding:10px 20px;background-color:#007BFF;color:white;text-decoration:none;border-radius:5px;"
    ) Login to Stealth IMS
  p If you have any questions or need assistance, please don't hesitate to contact our support team.
  p We appreciate your patience and look forward to having you as a valued member of our platform!
  p Best Regards,
  p Stealth
